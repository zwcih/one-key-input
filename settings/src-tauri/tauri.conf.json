{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "One-Key Input Settings",
  "version": "0.1.0",
  "identifier": "io.github.zwcih.onekey-input.settings",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "One-Key Input — Settings",
        "width": 880,
        "height": 720,
        "minWidth": 700,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
